{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/architecture-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking architecture guard..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/frankie-scope-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking Frankie scope guard..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/nucleus-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking nucleus package guard..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/orchestrator-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking orchestrator guard..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auditor-trigger.sh",
            "timeout": 30,
            "statusMessage": "Checking if architectural audit is needed..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/build-check.sh",
            "timeout": 120,
            "statusMessage": "Running TypeScript check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/scripts/captain-compile.mjs --root \"$CLAUDE_PROJECT_DIR\" --quiet"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/scripts/captain-compile.mjs --root \"$CLAUDE_PROJECT_DIR\" --summary"
          }
        ]
      }
    ]
  }
}
