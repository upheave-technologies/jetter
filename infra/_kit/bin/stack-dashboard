#!/usr/bin/env node
// ============================================================================
// stack-dashboard — Cross-project Stack instance tracker
// ============================================================================
// Single-file Node HTTP server, zero npm dependencies. Binds 127.0.0.1:42137 by
// default (overridable via STACK_DASHBOARD_PORT) and renders an HTML view +
// JSON API over ~/.stack/registry.json.
//
// Subcommands:
//   stack-dashboard            → start (idempotent) and open browser
//   stack-dashboard start [--quiet] [--foreground]
//   stack-dashboard stop
//   stack-dashboard status
//   stack-dashboard json
//   stack-dashboard restart
//   stack-dashboard install    → install as launchd plist (macOS) or systemd user unit (Linux)
//
// Reads state from ~/.stack/registry.json. Probes ports with a quick TCP connect.
// ============================================================================

const fs = require('node:fs');
const path = require('node:path');
const net = require('node:net');
const http = require('node:http');
const os = require('node:os');
const { spawn, spawnSync, execSync } = require('node:child_process');

const HOME = process.env.STACK_HOME || path.join(os.homedir(), '.stack');
const REGISTRY = path.join(HOME, 'registry.json');
const PORT_REGISTRY = path.join(HOME, 'port-registry.json');
const RUN_DIR = path.join(HOME, 'run');
const PID_FILE = path.join(RUN_DIR, 'dashboard.pid');
const LOG_FILE = path.join(RUN_DIR, 'dashboard.log');
const DASHBOARD_PORT = parseInt(process.env.STACK_DASHBOARD_PORT || '42137', 10);

const subcommand = process.argv[2] || 'start';
const args = process.argv.slice(3);

function ensureHome() {
  fs.mkdirSync(RUN_DIR, { recursive: true });
}

function loadRegistry() {
  try {
    return JSON.parse(fs.readFileSync(REGISTRY, 'utf8'));
  } catch {
    return { version: 1, instances: [] };
  }
}

function loadPortRegistry() {
  try {
    return JSON.parse(fs.readFileSync(PORT_REGISTRY, 'utf8'));
  } catch {
    return { version: 1, allocations: {} };
  }
}

function probe(port, timeoutMs = 500) {
  return new Promise(resolve => {
    const sock = net.createConnection({ host: '127.0.0.1', port, timeout: timeoutMs });
    let done = false;
    const finish = ok => {
      if (done) return;
      done = true;
      try { sock.destroy(); } catch {}
      resolve(ok);
    };
    sock.on('connect', () => finish(true));
    sock.on('error',   () => finish(false));
    sock.on('timeout', () => finish(false));
  });
}

async function computeState() {
  const reg = loadRegistry();
  const ports = loadPortRegistry();
  const instances = await Promise.all((reg.instances || []).map(async inst => {
    const probes = {};
    for (const [name, port] of Object.entries(inst.ports || {})) {
      if (!port) continue;
      probes[name] = { port, up: await probe(port) };
    }
    const upCount  = Object.values(probes).filter(p => p.up).length;
    const totalCount = Object.values(probes).length;
    let health = 'unknown';
    if (totalCount === 0) health = 'unknown';
    else if (upCount === totalCount) health = 'up';
    else if (upCount === 0) health = 'down';
    else health = 'partial';
    return { ...inst, probes, health, uptime_ms: inst.started_at ? Date.now() - new Date(inst.started_at).getTime() : null };
  }));
  return { version: 1, generated_at: new Date().toISOString(), instances, port_registry: ports };
}

function humanUptime(ms) {
  if (ms == null) return '—';
  const sec = Math.floor(ms / 1000);
  if (sec < 60) return `${sec}s`;
  const min = Math.floor(sec / 60);
  if (min < 60) return `${min}m`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr}h ${min % 60}m`;
  const d = Math.floor(hr / 24);
  return `${d}d ${hr % 24}h`;
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
}

function renderHtml(state) {
  const rows = state.instances.map(inst => {
    const ports = Object.entries(inst.probes || {}).map(([n, p]) => `${n}:${p.port}${p.up ? '' : '✗'}`).join(' ');
    const tagBits = [];
    if (inst.ephemeral) tagBits.push('🧪 ephemeral');
    const health = inst.health === 'up' ? '✅' : inst.health === 'partial' ? '⚠️' : inst.health === 'down' ? '❌' : '?';
    const urls = (inst.urls || []).slice(0, 2).map(u => `<a href="${escapeHtml(u)}" target="_blank">${escapeHtml(u)}</a>`).join(' · ');
    return `<tr>
      <td><b>${escapeHtml(inst.project)}</b></td>
      <td>${escapeHtml(inst.worktree)}</td>
      <td>${escapeHtml(inst.profile)}</td>
      <td class="ports">${escapeHtml(ports)}</td>
      <td class="health">${health} ${inst.health}</td>
      <td>${humanUptime(inst.uptime_ms)}</td>
      <td class="urls">${urls}</td>
      <td class="tags">${tagBits.join(' ')}</td>
    </tr>`;
  }).join('\n');

  const empty = state.instances.length === 0 ? `<p class="empty">No instances registered. Run <code>stack up</code> in any project.</p>` : '';
  return `<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Stack Dashboard</title>
<style>
  body { font: 14px/1.4 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 24px; background: #0d1117; color: #c9d1d9; }
  h1 { font-size: 18px; margin: 0 0 4px; color: #f0f6fc; }
  .meta { font-size: 12px; color: #8b949e; margin-bottom: 24px; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #21262d; font-size: 13px; vertical-align: middle; }
  th { font-weight: 600; color: #8b949e; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #30363d; }
  td.ports { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 12px; color: #79c0ff; }
  td.health { white-space: nowrap; }
  td.urls a { color: #58a6ff; text-decoration: none; margin-right: 6px; }
  td.urls a:hover { text-decoration: underline; }
  td.tags { color: #d29922; font-size: 12px; }
  code { background: #161b22; padding: 2px 6px; border-radius: 3px; font-size: 12px; }
  .empty { color: #8b949e; padding: 24px; text-align: center; border: 1px dashed #30363d; border-radius: 8px; }
  .footer { margin-top: 24px; font-size: 11px; color: #6e7681; }
</style>
</head>
<body>
  <h1>Stack Dashboard</h1>
  <div class="meta">Generated ${escapeHtml(state.generated_at)} · ${state.instances.length} instance${state.instances.length === 1 ? '' : 's'} · refresh: auto every 5s</div>
  ${empty}
  ${state.instances.length > 0 ? `<table>
    <thead><tr><th>Project</th><th>Worktree</th><th>Profile</th><th>Ports</th><th>Health</th><th>Uptime</th><th>URLs</th><th>Tags</th></tr></thead>
    <tbody>${rows}</tbody>
  </table>` : ''}
  <div class="footer">Registry: <code>${escapeHtml(REGISTRY)}</code> · Port: <code>${DASHBOARD_PORT}</code> · <a href="/api/state" style="color:#58a6ff">JSON</a></div>
  <script>setTimeout(() => location.reload(), 5000);</script>
</body>
</html>`;
}

function startServer({ quiet = false } = {}) {
  ensureHome();

  // PID file lock — if another process owns it and is alive, exit.
  if (fs.existsSync(PID_FILE)) {
    const pid = parseInt(fs.readFileSync(PID_FILE, 'utf8').trim(), 10);
    if (pid && processAlive(pid)) {
      if (!quiet) console.log(`Dashboard already running (pid ${pid}) at http://localhost:${DASHBOARD_PORT}`);
      return 0;
    } else {
      fs.unlinkSync(PID_FILE);
    }
  }

  let cache = null, cacheTs = 0;
  const server = http.createServer(async (req, res) => {
    const url = req.url || '/';
    const method = req.method || 'GET';

    // Cache state for 3s (probe cost)
    const now = Date.now();
    if (!cache || now - cacheTs > 3000) {
      cache = await computeState();
      cacheTs = now;
    }
    const state = cache;

    if (method === 'POST' && url === '/api/refresh') {
      cache = null;
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end('{"ok":true}');
      return;
    }

    if (url === '/' || url === '/index.html') {
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      res.end(renderHtml(state));
      return;
    }
    if (url === '/api/state') {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(state, null, 2));
      return;
    }
    if (url === '/api/instances') {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(state.instances, null, 2));
      return;
    }
    const m = url.match(/^\/api\/instances\/(.+)$/);
    if (m) {
      const inst = state.instances.find(i => i.id === m[1]);
      if (!inst) { res.writeHead(404); res.end('not found'); return; }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(inst, null, 2));
      return;
    }
    if (url === '/api/health') {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ ok: true, instances: state.instances.length, port: DASHBOARD_PORT }));
      return;
    }
    res.writeHead(404, { 'Content-Type': 'text/plain' });
    res.end('not found');
  });

  server.listen(DASHBOARD_PORT, '127.0.0.1', () => {
    fs.writeFileSync(PID_FILE, String(process.pid));
    if (!quiet) console.log(`Stack Dashboard listening at http://localhost:${DASHBOARD_PORT}`);
  });
  server.on('error', err => {
    console.error(`Dashboard failed to start: ${err.message}`);
    process.exit(1);
  });

  // Cleanup on exit
  const cleanup = () => { try { fs.unlinkSync(PID_FILE); } catch {} process.exit(0); };
  process.on('SIGINT', cleanup);
  process.on('SIGTERM', cleanup);
}

function processAlive(pid) {
  try { process.kill(pid, 0); return true; } catch { return false; }
}

function startDaemon({ quiet = false } = {}) {
  ensureHome();
  if (fs.existsSync(PID_FILE)) {
    const pid = parseInt(fs.readFileSync(PID_FILE, 'utf8').trim(), 10);
    if (pid && processAlive(pid)) {
      if (!quiet) console.log(`Dashboard already running (pid ${pid})`);
      return;
    }
  }
  const out = fs.openSync(LOG_FILE, 'a');
  const child = spawn(process.execPath, [__filename, 'start', '--foreground', ...(quiet ? ['--quiet'] : [])], {
    detached: true,
    stdio: ['ignore', out, out],
  });
  child.unref();
  // Wait briefly to confirm it started.
  const deadline = Date.now() + 2000;
  while (Date.now() < deadline) {
    if (fs.existsSync(PID_FILE)) break;
    execSync('sleep 0.1');
  }
  if (!quiet) console.log(`Dashboard started (pid ${child.pid}) at http://localhost:${DASHBOARD_PORT}`);
  if (!quiet && process.platform === 'darwin') {
    spawn('open', [`http://localhost:${DASHBOARD_PORT}`], { detached: true, stdio: 'ignore' }).unref();
  }
}

function stopDaemon() {
  if (!fs.existsSync(PID_FILE)) {
    console.log('Dashboard not running.');
    return;
  }
  const pid = parseInt(fs.readFileSync(PID_FILE, 'utf8').trim(), 10);
  if (!pid || !processAlive(pid)) {
    fs.unlinkSync(PID_FILE);
    console.log('Dashboard not running (stale pid file removed).');
    return;
  }
  try { process.kill(pid, 'SIGTERM'); } catch {}
  for (let i = 0; i < 20; i++) {
    if (!processAlive(pid)) break;
    execSync('sleep 0.1');
  }
  try { fs.unlinkSync(PID_FILE); } catch {}
  console.log(`Dashboard stopped (was pid ${pid}).`);
}

function statusDaemon() {
  if (!fs.existsSync(PID_FILE)) { console.log('Dashboard: NOT RUNNING'); return 1; }
  const pid = parseInt(fs.readFileSync(PID_FILE, 'utf8').trim(), 10);
  if (!pid || !processAlive(pid)) { console.log('Dashboard: NOT RUNNING (stale pid file)'); return 1; }
  console.log(`Dashboard: RUNNING (pid ${pid}, port ${DASHBOARD_PORT})`);
  console.log(`URL: http://localhost:${DASHBOARD_PORT}`);
  return 0;
}

async function printJson() {
  const state = await computeState();
  console.log(JSON.stringify(state, null, 2));
}

function installService() {
  if (process.platform === 'darwin') {
    const plist = path.join(os.homedir(), 'Library/LaunchAgents/tech.upheave.stack-dashboard.plist');
    fs.mkdirSync(path.dirname(plist), { recursive: true });
    fs.writeFileSync(plist, `<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>tech.upheave.stack-dashboard</string>
  <key>ProgramArguments</key><array>
    <string>${process.execPath}</string>
    <string>${path.resolve(__filename)}</string>
    <string>start</string>
    <string>--foreground</string>
    <string>--quiet</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>${LOG_FILE}</string>
  <key>StandardErrorPath</key><string>${LOG_FILE}</string>
</dict></plist>
`);
    spawnSync('launchctl', ['unload', plist], { stdio: 'ignore' });
    spawnSync('launchctl', ['load', plist], { stdio: 'inherit' });
    console.log(`Installed launchd plist at ${plist}`);
    return;
  }
  if (process.platform === 'linux') {
    const unit = path.join(os.homedir(), '.config/systemd/user/stack-dashboard.service');
    fs.mkdirSync(path.dirname(unit), { recursive: true });
    fs.writeFileSync(unit, `[Unit]
Description=Nucleus Stack Kit Dashboard
After=default.target

[Service]
ExecStart=${process.execPath} ${path.resolve(__filename)} start --foreground --quiet
Restart=on-failure

[Install]
WantedBy=default.target
`);
    spawnSync('systemctl', ['--user', 'daemon-reload'], { stdio: 'inherit' });
    spawnSync('systemctl', ['--user', 'enable', '--now', 'stack-dashboard.service'], { stdio: 'inherit' });
    console.log(`Installed systemd user unit at ${unit}`);
    return;
  }
  console.error(`Unsupported platform: ${process.platform}`);
  process.exit(1);
}

// -------------------------------------------------------------------------
// Dispatch
// -------------------------------------------------------------------------
switch (subcommand) {
  case 'start': {
    if (args.includes('--foreground')) startServer({ quiet: args.includes('--quiet') });
    else startDaemon({ quiet: args.includes('--quiet') });
    break;
  }
  case 'stop':    stopDaemon(); break;
  case 'restart': stopDaemon(); startDaemon({ quiet: args.includes('--quiet') }); break;
  case 'status':  process.exit(statusDaemon()); break;
  case 'json':    printJson(); break;
  case 'install': installService(); break;
  default:
    // Default: start if not running and open browser.
    startDaemon({ quiet: false });
}
