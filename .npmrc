@upheave-technologies:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

# Hoist all deps to the workspace-root node_modules (npm-style flat layout).
# Required because files under modules/ import deps declared in apps/core/package.json,
# and pnpm's default isolated layout makes those unresolvable from outside apps/core.
shamefully-hoist=true
